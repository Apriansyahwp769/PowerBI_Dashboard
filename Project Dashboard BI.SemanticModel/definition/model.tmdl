		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["INFLASI_KOMODITAS_ANDIL_KELOMPOK","INFLASI_PERDAERAH","KOMODITAS_ANDIL_INFASI_DEFLASI","PDRB SUMSEL - 1","PDRB SUMSEL - 2","PERKEMBANGAN_KOMODITAS_HARGA (fix)","PERKEMBANGAN_KOMODITAS_STOK","PUR","PUR_ESTIMASI_KEBUTUHAN","PUR_KAS_TITIPAN","PUR_POSISI_KAS_EDAR","REALISASI_ANGGARAN","SISTEM_PEMBAYARAN","SP_KK","SPP_UE","STABILITAS KEUANGAN","TARGET_QRIS","SP_QRIS"]

annotation PBI_ProTooling = ["DevMode"]

ref table INFLASI_KOMODITAS_ANDIL_KELOMPOK
ref table INFLASI_PERDAERAH
ref table KOMODITAS_ANDIL_INFASI_DEFLASI
ref table 'PDRB SUMSEL - 1'
ref table 'PDRB SUMSEL - 2'
ref table 'PERKEMBANGAN_KOMODITAS_HARGA (fix)'
